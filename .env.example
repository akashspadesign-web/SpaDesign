# ─────────────────────────────────────────────────────────────────────
# SPA Design Consultants — environment variables
# Copy this file to `.env` (or `.env.local`) and fill in values locally.
# `.env` is gitignored. Do NOT commit secrets.
# ─────────────────────────────────────────────────────────────────────

# Prisma datasource.
# Dev default: SQLite at ./prisma/dev.db.
# To switch to Postgres/Supabase, change provider in prisma/schema.prisma and
# set a postgresql:// URL here. No app code needs to change.
# Note: SQLite `file:` URLs are resolved RELATIVE TO THE SCHEMA FILE
# (prisma/schema.prisma), not relative to the project root. So `./dev.db`
# below lives at `prisma/dev.db` on disk. This is a Prisma quirk worth knowing.
DATABASE_URL="file:./dev.db"

# Admin login. The dashboard at /admin uses a single credential pair.
# Change both for any real deployment.
ADMIN_EMAIL="admin@spadesign.in"
ADMIN_PASSWORD="change-me"

# Secret used to HMAC-sign the admin session cookie.
# Must be 32+ random chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="generate-a-32-plus-char-random-string-and-paste-it-here"
